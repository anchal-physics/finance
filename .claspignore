# Denylist mode — files clasp should NOT push.
# Everything else in this folder is pushed. This prevents future
# `clasp push` from deleting remote files we don't have locally.

.git/**
.gitignore
node_modules/**
*.xlsx
*.md
*.png
logo/**
error_message.txt
.clasp.json
.clasprc.json
.claspignore
setup.sh
